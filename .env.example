# Copie para .env e preencha os valores. Em nova instalação, após restaurar um backup, configure aqui as variáveis (não use o .env do ambiente antigo).

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados
# SQLite (padrão): não defina USE_POSTGRES ou use USE_POSTGRES=false
DB_PATH=./data/database/chamados.db

# PostgreSQL (ex.: Docker local ou Railway)
# USE_POSTGRES=true
# DATABASE_URL=postgresql://erp:erp_local@localhost:5432/erp_prime

# JWT
JWT_SECRET=altere_para_uma_chave_secreta_forte
JWT_EXPIRES_IN=24h

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ERP PRIME <noreply@erpprime.com>

# Storage (uploads e imagens)
UPLOAD_PATH=./storage/uploads
UPLOADS_PATH=./storage/uploads
IMAGES_PATH=./storage/images

# SMS (Infobip)
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_API_KEY=
INFOBIP_SENDER=

# URL do frontend (links em e-mails)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Nome do sistema
SYSTEM_NAME=ERP PRIME

# SQL Server (módulo Cadastros - opcional)
DB_SERVER=
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# CORS (produção)
# ALLOWED_ORIGINS=https://seudominio.com

# URL pública do backend (formulários/QR e redirect HTTPS em dev)
# Use quando o backend estiver atrás de túnel (ex.: Cloudflare Tunnel) ou para links de formulário.
# Ex.: https://seu-backend.trycloudflare.com — em dev evita redirect HTTPS→HTTP e QR usa esta URL.
# Se não definir, mantém comportamento atual (Ngrok detectado automaticamente ou hostname/rede local).
# PUBLIC_URL=https://seu-backend.trycloudflare.com

# ============================================
# Satélite Railway (formulários públicos de motoristas — opcional)
# ============================================
# Quando SATELLITE_BASE_URL e SATELLITE_AUTH_TOKEN estão definidos, o ERP empurra snapshots
# de formulários publicados, importa chegadas por polling e atualiza estado no satélite.
# No Railway (pasta RailwaySatellite): use o mesmo valor em INTERNAL_AUTH_TOKEN.
# SATELLITE_BASE_URL=https://seu-satelite.up.railway.app
# SATELLITE_AUTH_TOKEN=defina_um_token_longo_aleatorio
# URL pública se for diferente da base (ex.: domínio customizado apontando ao mesmo serviço)
# SATELLITE_PUBLIC_URL=https://forms.seudominio.com
# Intervalo mínimo efetivo de polling: 15000 ms
# SATELLITE_POLL_INTERVAL_MS=60000

# ============================================
# Microsoft Entra ID (login com Microsoft)
# ============================================
# Obtenha no portal Azure: Azure Active Directory > App registrations > New registration
# Redirect URI no app: deve ser a URL do callback do backend (ex.: http://localhost:3004/api/auth/microsoft/callback)
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=http://localhost:3004/api/auth/microsoft/callback

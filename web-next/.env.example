# Copie para .env.local na pasta web-next.

# Quando corre `next dev` (porta 3001) e o backend Express está na 3000, defina a origem da API:
# NEXT_PUBLIC_BACKEND_ORIGIN=http://127.0.0.1:3000

# Deploy com front e API em hosts diferentes (equivalente ao antigo VITE_API_URL):
# NEXT_PUBLIC_API_URL=https://api.seudominio.com

# Opcional: mesmo efeito que NEXT_PUBLIC_API_URL para só a origem (sem path).
# NEXT_PUBLIC_BACKEND_ORIGIN=https://api.seudominio.com

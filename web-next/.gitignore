# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Variáveis locais (não versionar). Templates como .env.example podem ir ao Git.
.env
.env.*
!.env.example
!.env.template

# vercel
.vercel

# typescript
*.tsbuildinfo
# next-env.d.ts é gerado pelo Next; versionar melhora DX/CI (não ignorar)
